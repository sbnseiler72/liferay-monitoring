# =============================================================================
# Liferay Monitor Stack — Configuration
# Edit this file to match your Liferay environment
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Docker network name of your Liferay stack
# This is the network your liferay, db, nginx containers are on.
# Find it with: docker network ls
# -----------------------------------------------------------------------------
LIFERAY_NETWORK=liferay-backend

# -----------------------------------------------------------------------------
# REQUIRED — Container names in your Liferay stack
# Find them with: docker ps --format "{{.Names}}"
# -----------------------------------------------------------------------------
LIFERAY_CONTAINER=liferay
NGINX_CONTAINER=web-server
DB_CONTAINER=db

# -----------------------------------------------------------------------------
# REQUIRED — PostgreSQL credentials (must match your liferay stack .env)
# -----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=liferay
POSTGRES_PASSWORD=change_me
POSTGRES_DB=portal737

# -----------------------------------------------------------------------------
# REQUIRED — Grafana admin password
# -----------------------------------------------------------------------------
GRAFANA_PASSWORD=change_me_secure

# -----------------------------------------------------------------------------
# Liferay JMX — must match port exposed in your liferay container
# Default: 9999 (add to setenv.sh — see docs/01-setenv-additions.sh)
# -----------------------------------------------------------------------------
LIFERAY_JMX_HOST=liferay
LIFERAY_JMX_PORT=9999

# -----------------------------------------------------------------------------
# Nginx stub_status endpoint
# Default path — see docs/02-nginx-additions.conf for setup
# -----------------------------------------------------------------------------
NGINX_STUB_STATUS_URL=http://web-server/stub_status

# -----------------------------------------------------------------------------
# Grafana access URL (where Grafana will be reachable from browser)
# Options:
#   Via subdomain:  https://monitor.yourdomain.com
#   Via subpath:    https://yourdomain.com/monitoring
#   Direct port:    http://YOUR_SERVER_IP:3000
# -----------------------------------------------------------------------------
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_SERVE_FROM_SUBPATH=false

# -----------------------------------------------------------------------------
# Prometheus data retention
# -----------------------------------------------------------------------------
PROMETHEUS_RETENTION=30d

# -----------------------------------------------------------------------------
# Alert thresholds — tune to your environment
# -----------------------------------------------------------------------------
# JVM heap % to trigger WARNING alert (0.0 - 1.0)
ALERT_HEAP_WARN=0.70
# JVM heap % to trigger CRITICAL alert
ALERT_HEAP_CRIT=0.85
# Tomcat thread pool % busy to trigger WARNING
ALERT_THREAD_WARN=0.60
# Tomcat thread pool % busy to trigger CRITICAL
ALERT_THREAD_CRIT=0.80
# Container memory WARNING in bytes (default 11GB)
ALERT_CONTAINER_MEM_WARN=11000000000
# Container memory CRITICAL in bytes (default 13GB)
ALERT_CONTAINER_MEM_CRIT=13000000000

# -----------------------------------------------------------------------------
# NGINX Logs Path — Host directory where Nginx writes json_access.log
# -----------------------------------------------------------------------------
NGINX_LOG_PATH=/var/log/nginx
